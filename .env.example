# Copy this file to .env and fill in values as needed.

# Optional. If set, replies are generated by the LLM and grounded in the business
# profile. If left empty, the agent uses a deterministic rule based fallback.
OPENAI_API_KEY=

# Optional. Override the default chat model.
OPENAI_MODEL=gpt-4o-mini

# Optional. Path to the business profile YAML. Defaults to config/business.yaml.
BUSINESS_CONFIG=config/business.yaml
